# Copy to .env for local reference. These live in InsForge Secret Manager in prod
# (npx @insforge/cli secrets add <KEY> <value>) - never ship them to the browser.

# You.com Search API key (X-API-Key from api.you.com)
YOUCOM_API_KEY=

# InsForge model gateway + functions host. Base is your project URL.
INSFORGE_API_URL=https://YOUR-PROJECT.insforge.dev
INSFORGE_API_KEY=

# Optional: only set if the records/data API lives on a different host than the
# gateway (docs show *.insforge.app for data vs *.insforge.dev for the gateway).
# Leave blank to reuse INSFORGE_API_URL. Confirm with: npx @insforge/cli metadata
# INSFORGE_DATA_URL=https://YOUR-PROJECT.insforge.app

# Optional model overrides
JUDGE_MODEL=anthropic/claude-3.5-sonnet
EXTRACT_MODEL=anthropic/claude-3.5-haiku
SEARCH_COUNT=6
